{
  "name": "effect-prosemirror",
  "version": "0.0.0",
  "description": "Effect-managed runtime and extension model for ProseMirror.",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./core/Command": {
      "types": "./dist/core/Command.d.ts",
      "default": "./dist/core/Command.js"
    },
    "./core/Editor": {
      "types": "./dist/core/Editor.d.ts",
      "default": "./dist/core/Editor.js"
    },
    "./core/Error": {
      "types": "./dist/core/Error.d.ts",
      "default": "./dist/core/Error.js"
    },
    "./core/Extension": {
      "types": "./dist/core/Extension.d.ts",
      "default": "./dist/core/Extension.js"
    },
    "./core/Priority": {
      "types": "./dist/core/Priority.d.ts",
      "default": "./dist/core/Priority.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "effect": "^3.19.6",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "expect-type": "^1.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
